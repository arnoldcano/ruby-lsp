{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "ruby-lsp",
  "description": "Ruby LSP integration for Claude Code",
  "owner": {
    "name": "Arnold Cano"
  },
  "plugins": [
    {
      "name": "ruby-lsp",
      "description": "Ruby LSP integration for Claude Code",
      "version": "1.0.2",
      "source": "./",
      "category": "development",
      "lspServers": {
        "ruby": {
          "command": "ruby-lsp",
          "extensionToLanguage": {
            ".rb": "ruby",
            ".erb": "erb",
            ".rake": "ruby",
            ".gemspec": "ruby",
            ".ru": "ruby",
            "Rakefile": "ruby"
          }
        }
      }
    }
  ]
}
